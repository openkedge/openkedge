{
  "name": "openkedge",
  "version": "0.1.0",
  "description": "Intent-based mutation governance framework",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "okg": "dist/cli/index.js"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/index.js serve",
    "dev": "ts-node src/cli/index.ts serve",
    "cli": "ts-node src/cli/index.ts",
    "dev:replay-ui": "npm --workspace apps/replay-ui run dev",
    "demo:replay": "ts-node src/examples/replay-demo.ts",
    "demo:aws": "ts-node src/examples/aws-demo.ts",
    "demo:aws-identity": "ts-node src/examples/aws-identity-demo.ts",
    "demo:blast": "ts-node src/examples/blast-radius-demo.ts",
    "build:replay-ui": "npm --workspace apps/replay-ui run build",
    "test": "jest --runInBand"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1029.0",
    "@aws-sdk/client-sts": "^3.1029.0"
  }
}
